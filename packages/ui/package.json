{
  "name": "@trackion/ui",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "node scripts/generate-exports.mjs",
    "build:components": "tsup src/components/*/*.tsx --format esm --dts --splitting false",
    "build:core": "tsup src/lib/index.ts src/providers/index.ts --format esm --dts --splitting false",
    "build": "pnpm run build:components && pnpm run build:core"
  },
  "peerDependencies": {
    "lucide-react": "^1.12.0",
    "@base-ui/react": "^1.4.1",
    "react": "^18 || ^19",
    "tailwindcss": "^4.2.4",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "recharts": "2.15.4",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    },
