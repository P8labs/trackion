    },
    "./button": {
      "import": "./dist/base/button.js",
      "types": "./dist/base/button.d.ts"
    },
    "./card": {
      "import": "./dist/base/card.js",
      "types": "./dist/base/card.d.ts"
    },
    "./chart": {
