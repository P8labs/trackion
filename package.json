{
  "name": "trackion",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "build:packages": "pnpm -r --filter @trackion/ui --filter @trackion/lib build",
    "build:desktop": "pnpm run build:packages && pnpm --filter @trackion/desktop build"
  }
}
