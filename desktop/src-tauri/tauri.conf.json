{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "trackion",
  "version": "0.1.0",
  "identifier": "in.p8labs.trackion",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "trackion",
        "width": 800,
        "height": 600,
        "minHeight": 600,
        "minWidth": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Utilities",
    "shortDescription": "Trackion - Product Analytics Platform",
    "publisher": "P8Labs",
    "copyright": "Copyright (c) P8Labs",
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": true,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "startMenuFolder": "Trackion",
        "installerIcon": "icons/icon.ico",
        "compression": "lzma",
        "displayLanguageSelector": false,
        "minimumWebview2Version": "110.0.1531.0",
        "languages": ["English"]
      },
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["trackion"]
      }
    },
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBN0FERDU1NjVFMTM5MEYKUldRUE9lRmxWZDE2S29Tdm9BT0E2UFRyS09KNmJDc1lZVEQxWWpNQThLSmpXdXVlK2lqQUQ1NmUK",
      "endpoints": [
        "https://github.com/P8labs/trackion/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
